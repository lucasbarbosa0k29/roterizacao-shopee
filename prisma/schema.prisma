datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

enum SubscriptionPlanCode {
  FREE
  BASIC
  PRO
}

enum UserSubscriptionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum SubscriptionSource {
  ADMIN_GRANT
  TRIAL
  INFINITEPAY_LINK
  MANUAL_PAYMENT
}

enum RouteUsageSource {
  SUBSCRIPTION_DAILY
  EXTRA_CREDIT
  ADMIN_OVERRIDE
  FREE
}

enum RouteCreditReason {
  ADMIN_GRANT
  MANUAL_PAYMENT
  ADJUSTMENT
  CONSUMPTION
}

enum PaymentProvider {
  MERCADOPAGO
  ASAAS
}

enum PaymentProductType {
  EXTRA_ROUTE
  BASIC_PLAN
  PRO_PLAN
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  APPROVED
  REJECTED
  CANCELED
  REFUNDED
  EXPIRED
  FULFILLED
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  password          String
  role              Role      @default(USER)
  active            Boolean   @default(true)
  accessBlockedAt   DateTime?
  accessBlockReason String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  importJobs          ImportJob[]
  subscriptions       UserSubscription[]   @relation("UserSubscriptions")
  routeUsages         RouteUsage[]
  routeCredits        RouteCredit[]
  paymentTransactions PaymentTransaction[]
  adminActionLogs     AdminAccessLog[]     @relation("AdminActor")
  targetActionLogs    AdminAccessLog[]     @relation("AdminTarget")

  @@index([role])
  @@index([active])
  @@index([createdAt])
  @@index([accessBlockedAt])
}

enum ImportStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum ApiUsagePeriodType {
  MONTH
  DAY
}

model ImportJob {
  id String @id @default(cuid())

  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  routeUsage RouteUsage?

  fileHash     String?
  originalName String?
  storedName   String?
  status       ImportStatus @default(PENDING)

  totalStops     Int @default(0)
  processedStops Int @default(0)

  errorMessage String?
  errorStack   String?

  startedAt  DateTime?
  finishedAt DateTime?

  // ✅ salva o resultado final do processamento (linhas/endereços)
  resultJson    Json?
  resultPath    String?   @db.Text
  resultSavedAt DateTime?

  // ✅ NOVO: salva o "estado da tela" (confirmado/revisão, agrupamentos, seleções etc.)
  workspaceJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, storedName])
  @@index([userId])
  @@index([userId, fileHash])
  @@index([status])
  @@index([createdAt])
  @@index([resultSavedAt])
}

model SubscriptionPlan {
  id              String               @id @default(cuid())
  code            SubscriptionPlanCode @unique
  name            String
  durationDays    Int?
  dailyRouteLimit Int                  @default(0)
  isUnlimited     Boolean              @default(false)
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  subscriptions UserSubscription[]

  @@index([isActive])
}

model UserSubscription {
  id               String                 @id @default(cuid())
  userId           String
  planId           String
  status           UserSubscriptionStatus @default(ACTIVE)
  source           SubscriptionSource
  startsAt         DateTime
  expiresAt        DateTime?
  grantedByAdminId String?
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  user        User             @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan @relation(fields: [planId], references: [id])
  routeUsages RouteUsage[]

  @@index([userId, status, expiresAt])
  @@index([planId])
  @@index([grantedByAdminId])
  @@index([createdAt])
}

model RouteUsage {
  id             String           @id @default(cuid())
  userId         String
  importJobId    String?          @unique
  subscriptionId String?
  source         RouteUsageSource
  usageDayKey    String
  createdAt      DateTime         @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  importJob    ImportJob?        @relation(fields: [importJobId], references: [id], onDelete: SetNull)
  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, usageDayKey])
  @@index([subscriptionId])
  @@index([createdAt])
}

model RouteCredit {
  id        String            @id @default(cuid())
  userId    String
  delta     Int
  reason    RouteCreditReason
  notes     String?
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PaymentTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider    PaymentProvider    @default(MERCADOPAGO)
  productType PaymentProductType
  quantity    Int                @default(1)
  amountCents Int
  currency    String             @default("BRL")
  status      PaymentStatus      @default(PENDING)

  mercadoPagoPreferenceId String?
  mercadoPagoPaymentId    String? @unique
  asaasPaymentId          String? @unique
  asaasCustomerId         String?
  asaasSubscriptionId     String?
  asaasCheckoutUrl        String?
  asaasInvoiceUrl         String?
  externalReference       String  @unique
  initPoint               String?
  sandboxInitPoint        String?

  approvedAt        DateTime?
  fulfilledAt       DateTime?
  fulfilledSourceId String?
  rawPayload        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([provider, status])
  @@index([productType, status])
  @@index([approvedAt])
}

model AdminAccessLog {
  id           String   @id @default(cuid())
  adminId      String
  targetUserId String
  action       String
  metadata     Json?
  createdAt    DateTime @default(now())

  admin      User @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser User @relation("AdminTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action])
}

//
// ✅ Memória GLOBAL de endereços (1 para todos os usuários)
//
model AddressMemory {
  id String @id @default(cuid())

  // chave normalizada do endereço (pra bater rápido e igual sempre)
  key String @unique

  // dados "final" que vamos reutilizar
  label String?
  lat   Float
  lng   Float

  // quem salvou (só pra auditoria - mas a memória é global)
  createdBy String?

  // estatística (opcional, ajuda a ver o que mais usa)
  hitCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model ApiUsageCounter {
  id         String             @id @default(cuid())
  service    String
  periodType ApiUsagePeriodType
  periodKey  String
  count      Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([service, periodType, periodKey])
  @@index([service, periodType, periodKey])
  @@index([createdAt])
}
